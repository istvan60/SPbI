# Build grid of combinations (Site, X, boot, radius)
combos_band <- tidyr::expand_grid(core_combos, radius_km = radius_seq)

# Function to calculate spatial metrics for one combination
calc_spatial_band <- function(Site, X, boot, radius_km) {
  subO  <- df_O18_trim[df_O18_trim$Site == Site, c("Date", "O18", "Altitude")]
  subH  <- df_H2_trim [df_H2_trim$Site  == Site, c("Date", "H2",  "Altitude")]
  dates <- subO$Date; yO <- subO$O18; yH <- subH$H2
  alt0  <- stations$Altitude[stations$Site == Site]
  
  rmv_dates <- removed_dates %>%
    dplyr::filter(Site == !!Site, X == !!X, boot == !!boot) %>%
    dplyr::pull(Date)
  
  idx <- match(rmv_dates, dates)
  idx <- idx[!is.na(idx) & idx >= 1 & idx <= length(yO)]
  if (length(idx) == 0) return(NULL)
  
  yO_na <- yO; yO_na[idx] <- NA_real_
  yH_na <- yH; yH_na[idx] <- NA_real_
  
  nbrs <- stations$Site[dist_km[Site, ] > 0 & dist_km[Site, ] <= radius_km]
  
  yO_imp <- yO_na; yH_imp <- yH_na
  for (j in idx) {
    nbr_data_O <- df_O18_trim %>%
      dplyr::filter(Site %in% nbrs, Date == dates[j]) %>%
      dplyr::mutate(O_corr = O18 + (Altitude - alt0) * 1.2 / 1000) %>%
      dplyr::pull(O_corr)
    if (any(is.finite(nbr_data_O))) yO_imp[j] <- mean(nbr_data_O, na.rm = TRUE)
    
    nbr_data_H <- df_H2_trim %>%
      dplyr::filter(Site %in% nbrs, Date == dates[j]) %>%
      dplyr::mutate(H_corr = H2 + (Altitude - alt0) * 7.9 / 1000) %>%
      dplyr::pull(H_corr)
    if (any(is.finite(nbr_data_H))) yH_imp[j] <- mean(nbr_data_H, na.rm = TRUE)
  }
  
  tibble::tibble(
    Site = Site, X = X, boot = boot, radius_km = radius_km,
    MAD_d18O  = mean(abs(yO[idx] - yO_imp[idx]), na.rm = TRUE),
    RMSE_d18O = sqrt(mean((yO[idx] - yO_imp[idx])^2, na.rm = TRUE)),
    MAD_d2H   = mean(abs(yH[idx] - yH_imp[idx]), na.rm = TRUE),
    RMSE_d2H  = sqrt(mean((yH[idx] - yH_imp[idx])^2, na.rm = TRUE))
  )
}

