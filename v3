radius_seq <- seq(50, 400, by = 50)

# all masked (Site, X, boot, Date) used by the core baselines
removed_dates <- all_imputed %>%
  dplyr::filter(method %in% core_keep) %>%
  dplyr::distinct(Site, X, boot, Date)

# keep exactly those (Site, X, boot) that exist up to dynamic n_boot_by_X[X]
boot_max_by_X <- tibble::tibble(X = X_vals, n_boot = n_boot_by_X)
core_combos <- removed_dates %>%
  dplyr::left_join(boot_max_by_X, by = "X") %>%
  dplyr::filter(boot <= n_boot) %>%
