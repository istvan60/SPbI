safe_fun <- function(fun) {
  function(x) {
    out <- tryCatch(fun(x), error = function(e) rep(NA_real_, length(x)))
    out[!is.finite(out)] <- NA_real_
    out
  }
}

impute_funs <- list(
  locf       = imputeTS::na_locf,
  linear     = function(x) imputeTS::na_interpolation(x, option = "linear"),
  spline     = function(x) imputeTS::na_interpolation(x, option = "spline"),
  stine      = function(x) imputeTS::na_interpolation(x, option = "stine"),
  kalman     = imputeTS::na_kalman,
  moving_avg = function(x) imputeTS::na_ma(x, k = 5)
)
impute_funs_safe <- purrr::map(impute_funs, safe_fun)

# sinusoidal seasonal imputation
impute_sin_nls <- function(x, dates) {
  start_m <- floor_date(min(dates,na.rm=TRUE),"month")
  t <- as.numeric(interval(start_m, floor_date(dates,"month"))/months(1)) + 1
  obs <- !is.na(x)
  df  <- data.frame(t=t[obs], y=x[obs])
  if(nrow(df)<3) return(rep(NA_real_, length(x)))
  A0 <- mean(df$y); B0 <- diff(range(df$y))/2; phi0 <- 0
  fit <- try(
    nlsLM(y ~ A + B*sin(2*pi*t/12 + phi), data=df,
          start=list(A=A0,B=B0,phi=phi0),
          lower=c(-Inf,-Inf,-2*pi), upper=c(Inf,Inf,2*pi),
          control=nls.lm.control(maxiter=200)),
    silent=TRUE
  )
  if(!inherits(fit,"nls")) return(rep(NA_real_, length(x)))
  co <- coef(fit)
  yhat <- co["A"] + co["B"] * sin(2*pi*t/12 + co["phi"])
  yhat[!is.finite(yhat)] <- NA_real_; yhat
}
safe_sin_nls <- function(x,dates) {
  out <- tryCatch(impute_sin_nls(x,dates),
                  error=function(e) rep(NA_real_,length(x)))
  out[!is.finite(out)] <- NA_real_; out
}

# spatial imputation for O18 — now using TRIMMED frames
spatial_impute_O18 <- function(x, dates, site, dist_km, stations) {
  alt0 <- stations$Altitude[stations$Site==site]
  out <- x
  for(j in which(is.na(x))) {
    nbrs <- stations$Site[ which(dist_km[site,]>0 & dist_km[site,]<=100) ]
    tmp <- df_O18_trim %>%
      filter(Site %in% nbrs, Date==dates[j]) %>%
      select(O18, Altitude) %>%
      mutate(O18c = O18 + (Altitude - alt0)*1.2/1000)
    if(any(!is.na(tmp$O18c))) out[j] <- mean(tmp$O18c,na.rm=TRUE)
  }
  out
}

# spatial imputation for H2 — now using TRIMMED frames
spatial_impute_H2 <- function(x, dates, site, dist_km, stations) {
  alt0 <- stations$Altitude[stations$Site==site]
  out <- x
  for(j in which(is.na(x))) {
    nbrs <- stations$Site[ which(dist_km[site,]>0 & dist_km[site,]<=100) ]
    tmp <- df_H2_trim %>%
      filter(Site %in% nbrs, Date==dates[j]) %>%
      select(H2, Altitude) %>%
      mutate(H2c = H2 + (Altitude - alt0)*7.9/1000)
    if(any(!is.na(tmp$H2c))) out[j] <- mean(tmp$H2c,na.rm=TRUE)
  }
  out
}

