# Rebuild ba_long with observed (original) values on X-axis
make_ba_long_obs <- function(df, var_label, orig_col, imp_col) {
  df %>%
    transmute(
      var    = var_label,
      method,
      X_pct,
      orig   = .data[[orig_col]],
      diff   = .data[[imp_col]] - .data[[orig_col]]
