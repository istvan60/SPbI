# ---- Robust topography fetch (metR variants -> marmap fallback) ----
get_topography_any <- function() {
  topo <- tryCatch(
    metR::GetTopography(lon.west = lon_w, lon.east = lon_e,
                        lat.south = lat_s, lat.north = lat_n,
                        resolution = 1/10),
    error = function(e) NULL
  )
  if (!is.null(topo)) return(topo)
  
  topo <- tryCatch(metR::GetTopography(lon_seq, lat_seq), error = function(e) NULL)
  if (!is.null(topo)) return(topo)
  
  topo <- tryCatch(metR::GetTopography(range(lon_seq), range(lat_seq), resolution = 1/30),
                   error = function(e) NULL)
  if (!is.null(topo)) return(topo)
  
  if (!requireNamespace("marmap", quietly = TRUE)) {
    stop("Topography download failed via metR, and 'marmap' is not installed. Please install.packages('marmap').")
  }
  bathy <- marmap::getNOAA.bathy(lon1 = lon_w, lon2 = lon_e,
                                 lat1 = lat_s, lat2 = lat_n,
                                 resolution = 1/10)
  topo_df <- marmap::as.xyz(bathy)         # x, y, z (depth, negative)
  names(topo_df) <- c("lon","lat","height")
  topo_df$height <- -topo_df$height        # convert depth to elevation
  topo_df
}

