make_iso_plot <- function(dat, ablines_df, iso = c("d18O", "d2H"),
                          base_size = 16, abline_width = 1.6,
                          point_size = 3) {
  
  iso <- match.arg(iso)
  
  iso_cols <- paste0(c("MAD_", "RMSE_"), iso)
  
  # Calculate statistics
  stats <- dat %>%
    select(X_pct, radius_fac, all_of(iso_cols)) %>%
    pivot_longer(all_of(iso_cols), names_to = "metric", values_to = "value") %>%
    mutate(metric = factor(if_else(grepl("^MAD", metric), "MAD", "RMSE"),
                           levels = c("MAD", "RMSE"))) %>%
    group_by(X_pct, radius_fac, metric) %>%
    summarise(n = sum(is.finite(value)),
              mean = mean(value, na.rm = TRUE),
              q_low = quantile(value, 0.25, na.rm = TRUE),  # 1st Quartile (Q1)
              q_high = quantile(value, 0.75, na.rm = TRUE), # 3rd Quartile (Q3)
              median = median(value, na.rm = TRUE),         # Median
              .groups = "drop")
  
  # Get the baseline values for the core methods (linear and sinusoid)
  ab_iso <- ablines_df %>% filter(iso == !!iso) %>% select(X_pct, metric, method, value)
  
  # Determine Y-axis limits per isotope
  y_limits <- if(iso == "d18O") c(0, 2.9) else if(iso == "d2H") c(0, 23) else NULL
  
  # Generate the boxplot
  ggplot(stats, aes(x = radius_fac, y = mean)) +
    # Boxplot of bandwise results
    geom_boxplot(
      aes(
        ymin = q_low,
        lower = q_low,
        middle = mean,
        upper = q_high,
        ymax = q_high
      ),
      stat = "identity",
      width = 0.5,
      fill = "lightblue",
      alpha = 0.5
    ) +
    # Core method lines (linear and sinusoid)
    geom_hline(data = ab_iso, aes(yintercept = value, color = method, linetype = method),
               linewidth = abline_width, alpha = 0.95) +
    facet_grid(rows = vars(X_pct), cols = vars(metric), scales = "free_y", switch = "y") +
    labs(title = paste0("Boxplots with Baselines (δ", ifelse(iso == "d18O", "18O", "2H"), ")"),
         x = "Radius (km)", y = "Error (‰)") +
    scale_linetype_manual(name = "Baseline", values = c(linear = "dashed", sinusoid = "dotted")) +
    scale_color_manual(name = "Baseline", values = c(linear = "brown", sinusoid = "#40E0D0")) +
    { if(!is.null(y_limits)) scale_y_continuous(limits = y_limits) } +
    theme_minimal(base_size = base_size) +
    theme(legend.position = "top",
          legend.key.width = unit(1.6, "cm"),
          strip.placement = "outside",
          strip.text = element_text(face = "bold"),
          axis.title = element_text(face = "bold"),
          panel.spacing.x = unit(0.35, "lines"),
          panel.spacing.y = unit(0.35, "lines"),
          plot.margin = margin(6, 8, 6, 8)) +
    guides(color = guide_legend(override.aes = list(linewidth = abline_width)),
           linetype = guide_legend(override.aes = list(linewidth = abline_width)))
}

# Call the function
p_d18O <- make_iso_plot(df_band, ablines_long, "d18O")
p_d2H  <- make_iso_plot(df_band, ablines_long, "d2H")

# Print the plots
